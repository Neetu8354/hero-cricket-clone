{
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://www.betfairbets.live/:path*",
      "has": [
        {
          "type": "host",
          "value": "betfairbets.live"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
